# Public site URL for sitemap, Open Graph, and JSON-LD (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://your-community.example

# Luma calendar API key(s). Requires Luma Plus on each calendar.
# Single calendar:
#   LUMA_API_KEY=secret-...
# Multiple calendars (comma-separated), e.g. Karachi + Lahore:
#   LUMA_API_KEYS=secret-...,secret-...
LUMA_API_KEY=
LUMA_API_KEYS=
